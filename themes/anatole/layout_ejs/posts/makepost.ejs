<%# id_detail=true %>
<div class="post animated fadeInDown">
  <div class="post-title">
    <h3>
      <a><%= page.title %></a>
    </h3>
  </div>
  <div class="post-information">
    <div class="meta">
      <div class="info">
        <i class="fa fa-sun-o"></i>
        <span class="date"><%= date(page.date, 'YYYY-MM-DD')%></span>
        <% if (theme.duoshuo || theme.disqus) { %>
          <i class="fa fa-comment-o"></i>
          <a href="<%= url_for(page.path) %>#comments"><%= __('Comments') %></a>
        <% } %>
        <% if (page.tags) { %>
          <i class="fa fa-tag"></i>
          <% page.categories.sort('posts').each(function(item) { %>
            <a href="<%= config.root + item.path %>" class="tag" title="<%= item.name %>"><%= item.name %> </a>
          <% }) %>
          <% page.tags.sort('posts').each(function(item) { %>
            <a href="<%= config.root + item.path %>" class="tag" title="<%= item.name %>"><%= item.name %> </a>
          <% }) %>
        <% } %>
      </div>
    </div>
    <div class="post-content"><%- page.content %></div>
  </div>
</div>
