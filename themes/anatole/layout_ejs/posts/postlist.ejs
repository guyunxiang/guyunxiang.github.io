<div class="archive">
  <% var year = 0; %>
  <% var change = false; %>
  <% var firstYear = true; %>
  <% page.posts.each(function(item) { %>
    <% var itemYear = date(item.date, 'YYYY') - 0; %>
    <% change = year !== itemYear; %>
    <% year = change ? itemYear : year; %>
    <% if (change) { %>
      <% if (firstYear) { %>
        <div class="listing-title"><%= year %></div>
        <ul class="listing">
        <% firstYear = false; %>
      <% } else { %>
        </ul><div class="listing-title"><%= year %></div>
        <ul class="listing">
      <% } %>
    <% } %>
    <li class="list-item">
      <div class="listing-post">
        <a href="<%= url_for(item.path) %>" title="<%= item.title %>"><%= item.title %></a>
        <div class="post-time">
          <span class="date"><%= date(item.date, 'MM-DD') %></span>
        </div>
      </div>
    </li>
  <% }); %>
</div>
