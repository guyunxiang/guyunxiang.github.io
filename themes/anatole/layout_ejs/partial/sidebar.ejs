<div class="sidebar animated fadeInDown">
  <div class="followme">
    <a href="//github.com/<%= theme.github %>" target="_blank">follow me</a>
  </div>
  <div class="logo-title">
    <div class="title">
      <img src="<%= url_for('images/logo@2x.png') %>" alt="" width="127px">
      <h3>
        <a href="/"><%= config.title %></a>
      </h3>
      <% if(theme.description) { %>
        <div class="description">
          <p><%= theme.description %></p>
        </div>
      <% } %>
    </div>
  </div>
  <ul class="social-links">
    <% if(theme.twitter) { %>
      <li>
        <a href="//twitter.com/<%= theme.twitter %>" target="_block">
          <i class="fa fa-twitter"></i>
        </a>
      </li>
    <% } %>
    <% if(theme.github) { %>
      <li>
        <a href="//github.com/<%= theme.github %>" target="_block">
          <i class="fa fa-github"></i>
        </a>
      </li>
    <% } %>
    <% if(theme.weibo) { %>
      <li>
        <a href="//weibo.com/<%= theme.weibo %>" target="_block">
          <i class="fa fa-weibo"></i>
        </a>
      </li>
    <% } %>
  </ul>
  <%- partial('partial/footer') %>
</div>
